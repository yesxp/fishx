{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^wd-(.*)": "@wot-ui/ui/components/wd-$1/wd-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/mine/index",
      "style": {
        "navigationBarTitleText": "我的",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/catch/create",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/catch/detail",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/catch/list",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/capture/index",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/species/detail",
      "style": {
        "navigationStyle": "custom"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "鱼渔娱",
    "navigationBarBackgroundColor": "#FFFFFF",
    "backgroundColor": "#F2F3F5"
  },
  "tabBar": {
    "color": "#80848E",
    "selectedColor": "#5865F2",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "今日",
        "iconPath": "static/tab/today.svg",
        "selectedIconPath": "static/tab/today-active.svg"
      },
      {
        "pagePath": "pages/mine/index",
        "text": "我的",
        "iconPath": "static/tab/mine.svg",
        "selectedIconPath": "static/tab/mine-active.svg"
      }
    ]
  }
}
