{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^wd-(.*)": "@wot-ui/ui/components/wd-$1/wd-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/weather/index",
      "style": {
        "navigationBarTitleText": "天时",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/map/index",
      "style": {
        "navigationBarTitleText": "钓点",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/mine/index",
      "style": {
        "navigationBarTitleText": "我的",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/login/index",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/catch/create",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/catch/detail",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/map/detail",
      "style": {
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/map/explore",
      "style": {
        "navigationStyle": "custom"
      }
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "鱼渔娱",
    "navigationBarBackgroundColor": "#FFFFFF",
    "backgroundColor": "#F2F3F5"
  },
  "tabBar": {
    "color": "#80848E",
    "selectedColor": "#5865F2",
    "backgroundColor": "#FFFFFF",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "static/tab/home.svg",
        "selectedIconPath": "static/tab/home-active.svg"
      },
      {
        "pagePath": "pages/weather/index",
        "text": "天时",
        "iconPath": "static/tab/weather.svg",
        "selectedIconPath": "static/tab/weather-active.svg"
      },
      {
        "pagePath": "pages/map/index",
        "text": "钓点",
        "iconPath": "static/tab/map.svg",
        "selectedIconPath": "static/tab/map-active.svg"
      },
      {
        "pagePath": "pages/mine/index",
        "text": "我的",
        "iconPath": "static/tab/mine.svg",
        "selectedIconPath": "static/tab/mine-active.svg"
      }
    ]
  }
}
