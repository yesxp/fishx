{
  "buildCommand": "npm run build:h5",
  "outputDirectory": "dist/build/h5",
  "framework": null,
  "installCommand": "npm install",
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs22.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ]
}
